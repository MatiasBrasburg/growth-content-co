# ============================================================
# FÁBRICA DE CONTENIDO VIRAL - CONFIGURACIÓN DE ENTORNO
# ============================================================
# Copia este archivo como .env y completa con tus claves.
# NUNCA subas el archivo .env a tu repositorio.
# ============================================================

# --- BASE DE DATOS (Supabase) ---
# URL de tu proyecto Supabase (ej: https://xxxxx.supabase.co)
VITE_SUPABASE_URL=
# Clave pública (anon) de Supabase - segura para el frontend
VITE_SUPABASE_ANON_KEY=
# Clave de servicio (service_role) - SOLO para el backend/Edge Functions
SUPABASE_SERVICE_ROLE_KEY=

# --- IA / ANÁLISIS (Google Gemini) ---
# Clave de API de Google Gemini para análisis de negocios y trends de video.
# Obtenla en: https://aistudio.google.com/apikey
# Sin límites de uso; usaremos nuestra propia key.
GEMINI_API_KEY=

# --- EXTRACCIÓN DE DATOS DE NEGOCIO (Labs Pomelli) ---
# API Key del proyecto Labs Pomelli para extraer contexto de marca
# (productos, público objetivo, tono de comunicación) a partir de una URL.
GOOGLE_POMELLI_API_KEY=

# --- REDES SOCIALES: ANALÍTICAS ---
# Instagram Graph API - Para métricas de alcance, engagement, seguidores.
# Configura en: https://developers.facebook.com/ (versión gratuita)
INSTAGRAM_GRAPH_API_KEY=

# TikTok Business API - Para métricas de rendimiento de videos.
# Regístrate en: https://developers.tiktok.com/
TIKTOK_BUSINESS_API_KEY=

# --- E-COMMERCE (Tiendanube) ---
# Token de acceso de la API de Tiendanube - Totalmente gratis.
# Para leer datos de ventas, conversiones y productos.
# Obténlo en: https://partners.tiendanube.com/
TIENDANUBE_API_ACCESS_TOKEN=

# --- SCRAPING DE TRENDS (Apify) ---
# Token de la API de Apify para ejecutar scrapers de TikTok/IG trends.
# Plan gratuito disponible en: https://apify.com/
APIFY_API_TOKEN=

# --- SERVIDOR LOCAL DE EDICIÓN DE VIDEO ---
# URL del servidor Python/C# local que maneja renderizado de video
# y clonación de voz. NO procesar video en el frontend.
# Ejemplo: http://localhost:8000
LOCAL_PYTHON_SERVER_URL=http://localhost:8000
